---
import BaseLayout from "../layouts/BaseLayout.astro";

const capabilities = [
  "Identity systems",
  "Brand development",
  "Packaging and print",
  "Posters and campaign graphics",
  "Commercial signage",
  "Websites and applications",
];

const clients = [
  "CVS",
  "Longs Drugs",
  "University of Hawaii",
  "Manoa Now",
  "KTUH Radio",
  "KTM Enjoy Snacks",
  "Aloha Gourmet",
  "Island Living",
  "Mondelez",
  "Rotary Hawaii",
  "United States Navy",
  "Vital View 3D",
  "Kelly Lui",
];

const aboutImages = [
  {
    src: "/images/about/about-strip-01.webp",
    alt: "Printed collateral and paper samples arranged across a design studio table.",
    caption: "Process",
  },
  {
    src: "/images/about/about-strip-02.webp",
    alt: "Typography proof sheets with letterforms, grid marks, and drawing tools.",
    caption: "Print",
  },
  {
    src: "/images/about/about-strip-03.webp",
    alt: "Retail storefront with blank sign panels, plants, and warm interior light.",
    caption: "Place",
  },
];

const everydayImages = [
  {
    src: "/images/about/everyday-01.webp",
    alt: "Blank packaging mockups, bottles, label cards, and material swatches on a studio surface.",
    caption: "Printed matter",
  },
  {
    src: "/images/about/everyday-02.webp",
    alt: "Gallery wall with blank framed posters, art prints, and proofs.",
    caption: "Spatial rhythm",
  },
  {
    src: "/images/about/everyday-03.webp",
    alt: "Storefront scene with blank window, wall, and sidewalk sign panels.",
    caption: "Street texture",
  },
  {
    src: "/images/about/everyday-04.webp",
    alt: "Apparel and merchandise mockups arranged with hangtags and print cards.",
    caption: "Pattern and shadow",
  },
];

const principles = [
  {
    title: "Clarity first",
    text: "The work has to be easy to understand before it can be memorable. I start by organizing the message, audience, and touchpoints.",
  },
  {
    title: "Systems over one-offs",
    text: "A good visual direction should hold together across a logo, package, poster, sign, website, or app screen.",
  },
  {
    title: "Place with restraint",
    text: "Moving from Hawaii to Seattle gives the work a sense of transition, texture, and atmosphere without leaning on obvious visual cliches.",
  },
];

const process = ["Listen", "Structure", "Design", "Extend"];
---

<BaseLayout
  title="About"
  description="About Christopher Abarca, a graphic designer with 10 years of experience in identity, brand, print, environmental, and digital design."
>
  <section class="about-hero">
    <div class="about-hero__copy" data-reveal>
      <p class="eyebrow">About</p>
      <h1>Graphic designer building brand systems across identity, print, environments, and digital products.</h1>
      <p>
        I am Christopher Abarca, a graphic designer with 10 years of experience creating identity, brand,
        print, environmental, and digital work. I am moving from Hawaii to Seattle and building a practice
        around clear visual systems, strong imagery, and practical design that can carry across many touchpoints.
      </p>
    </div>
    <div class="about-hero__card" data-reveal aria-label="Location transition">
      <span>HNL</span>
      <strong>Pacific point of view</strong>
      <em>SEA</em>
      <p>Graphic Designer. 10 years of experience. Open to freelance, full-time, and contract opportunities.</p>
    </div>
  </section>

  <section class="about-image-strip" aria-label="About page visual references">
    {
      aboutImages.map((image, index) => (
        <figure class:list={["about-image-strip__item", index === 1 && "about-image-strip__item--tall"]} data-reveal>
          <img src={image.src} alt={image.alt} loading="lazy" />
          <figcaption>
            <span>{String(index + 1).padStart(2, "0")}</span>
            {image.caption}
          </figcaption>
        </figure>
      ))
    }
  </section>

  <section class="about-grid about-grid--statement">
    <div class="about-grid__intro" data-reveal>
      <p class="eyebrow">Practice</p>
      <p>
        I work best where a brand has to show up in more than one place. That can mean an identity system,
        packaging direction, poster series, storefront sign, website, or application interface. The goal is
        to make each piece feel connected without making every touchpoint look identical.
      </p>
      <p>
        I care about the balance between structure and feeling. The structure makes the work useful. The
        feeling makes it worth remembering.
      </p>
    </div>
    <div class="about-grid__notes" data-reveal>
      <h2>Capabilities</h2>
      <ul>
        {capabilities.map((capability) => <li>{capability}</li>)}
      </ul>
    </div>
  </section>

  <section class="about-clients" aria-label="Selected clients and collaborators">
    <div data-reveal>
      <p class="eyebrow">Selected clients and collaborators</p>
      <h2>Experience across retail, education, food, media, civic, military, healthcare, and local business.</h2>
    </div>
    <ul data-reveal>
      {clients.map((client) => <li>{client}</li>)}
    </ul>
  </section>

  <section class="about-principles" aria-label="Design principles">
    {
      principles.map((principle, index) => (
        <article data-reveal>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h2>{principle.title}</h2>
          <p>{principle.text}</p>
        </article>
      ))
    }
  </section>

  <section class="about-process">
    <div data-reveal>
      <p class="eyebrow">How I work</p>
      <h2>A simple process for building visual systems that can keep expanding.</h2>
    </div>
    <ol data-reveal>
      {
        process.map((step) => (
          <li>
            <span>{step}</span>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="about-personal" data-reveal>
    <p class="eyebrow">Point of view</p>
    <p>
      Outside of project work, I pay attention to everyday design: storefronts, menus, posters, packaging,
      and the small details that make a place feel recognizable.
    </p>
  </section>

  <section class="about-everyday" aria-label="Everyday design references">
    {
      everydayImages.map((image) => (
        <figure data-reveal>
          <img src={image.src} alt={image.alt} loading="lazy" />
          <figcaption>{image.caption}</figcaption>
        </figure>
      ))
    }
  </section>

  <section class="index-band index-band--light" data-reveal>
    <div>
      <p class="eyebrow">Availability</p>
      <h2>Open to freelance, full-time, and contract opportunities in Seattle, Hawaii, and remote teams.</h2>
    </div>
    <a class="button" href="mailto:clukeabarca@icloud.com">Start a conversation</a>
  </section>
</BaseLayout>
