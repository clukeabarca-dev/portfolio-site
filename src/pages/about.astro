---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About Christopher Abarca, a graphic designer relocating from Hawaii to Seattle.">
  <section class="page-hero">
    <p class="eyebrow" data-reveal>About</p>
    <h1 data-reveal>A designer moving from Hawaii to Seattle with a practice built around clarity, rhythm, and place.</h1>
  </section>

  <section class="about-grid">
    <div class="about-grid__intro" data-reveal>
      <p>
        This portfolio is being rebuilt as both a brand system and a working archive. The goal is to show
        design work with the polish of a product launch and the usefulness of an editorial index.
      </p>
      <p>
        The brand direction uses Pacific warmth, Northwest restraint, precise typography, and tactile image
        treatment to create a site that feels personal without leaning on obvious location cliches.
      </p>
    </div>
    <div class="about-grid__notes" data-reveal>
      <h2>Focus</h2>
      <ul>
        <li>Identity systems</li>
        <li>Editorial design</li>
        <li>Campaign art direction</li>
        <li>Digital portfolio storytelling</li>
      </ul>
    </div>
  </section>

  <section class="index-band index-band--light" data-reveal>
    <div>
      <p class="eyebrow">Availability</p>
      <h2>Open to Seattle-based opportunities, freelance projects, and collaborative design work.</h2>
    </div>
    <a class="button" href="mailto:hello@example.com">Start a conversation</a>
  </section>
</BaseLayout>
